# Copy this file to ".env" (or ".env.local") and fill in your values.

# --- AI extraction ---------------------------------------------------------
# Google Gemini API key (free tier works fine for a family).
# Get one at: https://aistudio.google.com/apikey
# If left empty, the extractor falls back to a simple offline heuristic parser,
# so the app still runs without a key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Password protection (for public deployments) --------------------------
# When BOTH are set, the whole app requires HTTP Basic Auth with these creds.
# Leave empty for local dev to keep it open.
APP_USERNAME=
APP_PASSWORD=

# Shared secret so the WhatsApp gateway can POST to /api/extract past the
# password gate. Use a long random string. Set the SAME value on both services.
API_TOKEN=

# --- Storage ---------------------------------------------------------------
# Where the JSON store + uploaded photos live. On a host with a mounted volume
# set this to the volume path (e.g. /data). Defaults to ./data locally.
DATA_DIR=

# --- WhatsApp gateway (whatsapp/ service) ----------------------------------
# Full URL of the web app's extract endpoint.
API_URL=http://localhost:3000/api/extract
# Where Baileys stores its login/auth state (point at a volume in production).
AUTH_DIR=auth
# Optional: only process groups whose name contains this substring.
WA_GROUP=
